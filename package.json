{
  "name": "volunteer-management",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node scripts/run-with-env.mjs next dev",
    "build": "node scripts/run-with-env.mjs next build",
    "start": "node scripts/run-with-env.mjs next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-with-env.mjs vitest run",
    "check": "npm run lint && npm run typecheck",
    "setup:appwrite": "node scripts/run-with-env.mjs node scripts/setup-appwrite.mjs",
    "setup:appwrite:oauth": "node scripts/run-with-env.mjs node scripts/setup-appwrite-google-oauth.mjs"
  },
  "dependencies": {
    "appwrite": "^25.2.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "node-appwrite": "^25.2.0",
    "nodemailer": "^8.0.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
